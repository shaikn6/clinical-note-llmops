# .env.example — copy to .env and fill in real values before running.
# Never commit .env to version control.

# -----------------------------------------------------------------------
# REQUIRED IN PRODUCTION
# -----------------------------------------------------------------------

# API key for all /api/* endpoints.  Min 32 chars.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=REPLACE_WITH_A_RANDOM_64_HEX_CHARACTER_STRING

# Comma-separated list of trusted frontend origins allowed by CORS.
# Example: https://your-app.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# -----------------------------------------------------------------------
# HIPAA SCRUBBING
# -----------------------------------------------------------------------

# Set to "true" in production to refuse startup if Presidio is unavailable.
# Regex-only fallback does NOT detect patient names or all 18 HIPAA identifiers.
REQUIRE_PRESIDIO=false

# -----------------------------------------------------------------------
# PIPELINE
# -----------------------------------------------------------------------

MOCK_MODE=true
MOCK_S3=true
DATABASE_URL=sqlite:///./clinical_llmops.db
S3_AUDIT_BUCKET=hipaa-audit-logs

# Uncomment when MOCK_MODE=false and using real OpenAI:
# OPENAI_API_KEY=sk-...
